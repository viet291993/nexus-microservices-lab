# =========================
# Server
# =========================
# Cổng HTTP cho Inventory Service (NestJS)
PORT=8083

# =========================
# MongoDB
# =========================
# Chuỗi kết nối MongoDB.
# TODO: thay đổi user/pass/host theo môi trường thực tế.
MONGODB_URI=mongodb://YOUR_APP_USER:YOUR_APP_PASSWORD@localhost:27017/nexus_inventory?authSource=nexus_inventory

# =========================
# Kafka
# =========================
# Danh sách broker Kafka, phân tách bằng dấu phẩy nếu nhiều broker.
# Mặc định dùng 'kafka:9092' khi chạy trong Docker Network. 
# CHÚ Ý: Khi chạy Local cạnh Docker, hãy đổi thành 'localhost:29092' trong file .env của bạn.
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=inventory-service-client
KAFKA_GROUP_ID=inventory-service-group

# =========================
# Eureka (Service Discovery)
# =========================
# Địa chỉ Eureka Server để Inventory Service đăng ký.
# Dùng 'eureka-server' nếu chạy trong Docker Network.
EUREKA_HOST=eureka-server
EUREKA_PORT=8761

# Hostname/IP mà Inventory Service tự khai báo với Eureka.
# Mặc định dùng HOSTNAME hoặc 'localhost', nhưng khi deploy trên server/cluster
# bạn nên set rõ IP/hostname thật để Eureka và các service khác truy cập được.
SERVICE_HOST=inventory-service

