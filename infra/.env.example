# ========================
# Database & Infra Passwords
# ========================
# Lưu ý: Đây là file mẫu. Vui lòng tạo file .env và điền giá trị thực tế.

# PostgreSQL
POSTGRES_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD>

# MongoDB
MONGO_ROOT_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD>

# RabbitMQ
RABBITMQ_PASS=<REPLACE_WITH_STRONG_PASSWORD>

# Elasticsearch & Logstash
# Mật khẩu tài khoản 'elastic' (superuser)
ELASTIC_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD>
# Mật khẩu cho logstash_writer (least privilege)
LOGSTASH_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD>

# Keycloak
KEYCLOAK_ADMIN_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD>

# Grafana
GRAFANA_ADMIN_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD>

# ========================
# Kibana Configuration
# ========================
# Mật khẩu cho user 'kibana_system' (dùng để Kibana kết nối vào ES)
KIBANA_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD>

# Key mã hóa cho các đối tượng đã lưu trong Kibana (Yêu cầu 32 ký tự trở lên)
KIBANA_ENCRYPTION_KEY=<REPLACE_WITH_32_CHAR_SECURE_KEY>
